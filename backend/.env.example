# =============================================================================
# Database — DigitalOcean Managed PostgreSQL
# =============================================================================

DATABASE_URL=postgresql://user:pass@host:5432/sellibuy_prod

# Per-process pool size. Formula: floor((max_db_connections - 5) / total_process_count)
# On a 3-droplet fleet (12 processes): floor((97 - 5) / 12) = 7
DATABASE_POOL_SIZE=7

# =============================================================================
# Redis — DigitalOcean Managed Redis
# =============================================================================

REDIS_URL=redis://user:pass@host:6379/0

REDIS_SESSION_PREFIX=session:
REDIS_CACHE_PREFIX=cache:
REDIS_RATE_LIMIT_PREFIX=ratelimit:

# =============================================================================
# Authentication & Security
# =============================================================================

# Use cryptographically random 64-byte hex values
JWT_SECRET=
JWT_REFRESH_SECRET=

JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# =============================================================================
# Payment Gateway — DPO Group
# =============================================================================

DPO_COMPANY_TOKEN=
DPO_SECRET=                                 # HMAC-SHA512 webhook verification key
DPO_SANDBOX=true                            # Set false only on production after live key approval
DPO_API_URL=https://secure.3gdirectpay.com  # Sandbox: https://sandbox.dpogroup.com
DPO_PAYMENT_URL=https://pay.dpogroup.com

# =============================================================================
# SMS — Africa's Talking
# =============================================================================

AFRICATALKING_KEY=
AFRICATALKING_USERNAME=
AFRICATALKING_SENDER_ID=SELLIBUY            # Must be pre-registered with AT for Tanzania

# =============================================================================
# WhatsApp — Business API
# =============================================================================

WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# =============================================================================
# Email — SendGrid
# =============================================================================

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@sellibuy.co.tz
SENDGRID_FROM_NAME=SelliBuy

# =============================================================================
# File Storage — AWS S3 + CloudFront
# =============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=af-south-1                       # Cape Town; closest available to Tanzania
AWS_S3_BUCKET=sellibuy-prod
AWS_CLOUDFRONT_DOMAIN=https://cdn.sellibuy.co.tz
AWS_S3_PRESIGN_EXPIRY=900                   # 15 minutes (seconds) for presigned PUT URLs

# =============================================================================
# Monitoring & Error Tracking
# =============================================================================

SENTRY_DSN=
PROMETHEUS_ENDPOINT=
GRAFANA_URL=                                # Internal — not exposed publicly

# =============================================================================
# Infrastructure — Cloudflare
# =============================================================================

CLOUDFLARE_API_KEY=
CLOUDFLARE_ZONE_ID=

# =============================================================================
# Background Jobs — Celery
# =============================================================================

# Derived from REDIS_URL; no separate value needed
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_EXPIRES=86400                 # 24 hours (seconds)

# Scheduled job intervals (seconds)
ORDER_EXPIRY_SWEEP_INTERVAL=3600
AUTO_COMPLETE_SWEEP_INTERVAL=3600
DISPUTE_ESCALATE_SWEEP_INTERVAL=3600
ORPHAN_FILE_CLEANUP_INTERVAL=86400          # Daily S3 orphan cleanup

# Business rule durations — changing these changes platform behaviour
ORDER_EXPIRY_HOURS=24                       # PAYMENT_PENDING → CANCELLED after N hours
AUTO_COMPLETE_DAYS=7                        # DELIVERED → COMPLETED after N days without dispute
DISPUTE_ESCALATE_DAYS=14                    # Dispute escalation threshold

# =============================================================================
# Feature Flags
# =============================================================================

ENABLE_WHATSAPP=false                       # Enable when AT capacity confirmed
ENABLE_OFFLINE_SYNC=true                    # Must never be false in prod
ENABLE_AUTO_COMPLETE=true
ENABLE_SUPPLIER_CSV=false                   # Removed from MVP per §10.5
ENABLE_AGENT_DISTANCE_SORT=false            # Removed from MVP per §11.2

# =============================================================================
# Offline Sync — Agent App (Expo)
# =============================================================================
# Set in the Expo build environment, not the FastAPI server.

EXPO_API_BASE_URL=https://api.sellibuy.co.tz
EXPO_SYNC_RETRY_ATTEMPTS=5
EXPO_SYNC_RETRY_BACKOFF_MS=2000             # Exponential backoff base: 2s, 4s, 8s, 16s, 32s
EXPO_OFFLINE_STORAGE_WARNING_MB=100
